# Provider selection: "anthropic" (default) or "openai"
LLM_PROVIDER=anthropic

# Required for LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Required for LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

OBSIDIAN_VAULT_PATH=/Users/freddy/Documents/fred's vault
WIKI_SUBFOLDER=wiki

# Model overrides (defaults: anthropic → claude-sonnet-4-6 / claude-haiku-4-5-20251001;
# openai → gpt-4o / gpt-4o-mini)
# EXTRACTION_MODEL=
# OCR_MODEL=

# Optional: model used for the auto-granularity classifier. Defaults to a small/fast model per provider.
# GRANULARITY_PICKER_MODEL=

MAX_CONCURRENT_PDFS=3
OCR_TEXT_THRESHOLD=100
